// ─────────────────────────────────────────────────────────────────────────────
// OpenKPI Studio — Prisma schema
// ─────────────────────────────────────────────────────────────────────────────
// Models:
//   - NextAuth: User, Account, Session, VerificationToken
//   - Multi-tenant: Workspace, Membership (User ↔ Workspace with Role)
//   - Domain:    Kpi, KpiHistoryPoint, LineageFlow, LineageStep, AiConversation,
//                AiMessage, AuditEvent, SourceConnection (Phase B)
// All domain models scope by workspaceId for tenant isolation.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth core ───────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  auditEvents   AuditEvent[]
  conversations AiConversation[]
}

// ─── Tenancy ─────────────────────────────────────────────────────────────────
enum Role {
  ADMIN   // create/delete workspace, invite, billing, all rights
  STEWARD // certify KPIs, edit definitions, connect data sources
  EDITOR  // edit KPIs in Draft, propose changes
  VIEWER  // read-only
}

enum Visibility {
  PUBLIC   // anyone with the URL can view; members can edit
  PRIVATE  // only members can view or edit
}

model Workspace {
  id         String     @id @default(cuid())
  slug       String     @unique // url segment, e.g. "acme-finance"
  name       String
  tagline    String?
  currency   String     @default("USD")
  visibility Visibility @default(PRIVATE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  memberships       Membership[]
  kpis              Kpi[]
  lineageFlows      LineageFlow[]
  conversations     AiConversation[]
  auditEvents       AuditEvent[]
  sourceConnections SourceConnection[]
  invitations       Invitation[]
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(VIEWER)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Invitation {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  role        Role     @default(VIEWER)
  token       String   @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

// ─── Domain: KPIs ────────────────────────────────────────────────────────────
enum KpiStatus {
  DRAFT
  CERTIFIED
  NEEDS_REVIEW
}

enum KpiDomain {
  FINANCE
  HR
  PROCUREMENT
  OPERATIONS
  SALES
  DATA
  CUSTOM
}

enum KpiTrend {
  UP
  DOWN
  FLAT
}

enum KpiUnit {
  PERCENT
  CURRENCY
  DAYS
  SCORE
  RATIO
  COUNT
}

model Kpi {
  id          String   @id @default(cuid())
  workspaceId String
  slug        String   // unique within workspace, used in URLs
  name        String
  domain      KpiDomain
  customDomain String?  // when domain == CUSTOM

  value         Float
  previousValue Float
  unit          KpiUnit
  goodWhenUp    Boolean    @default(true)
  trend         KpiTrend
  status        KpiStatus  @default(DRAFT)

  owner             String
  sourceSystem      String
  refreshFrequency  String
  lastRefresh       DateTime?
  confidenceScore   Int        @default(70) // 0..100

  definition   String   @db.Text
  formula      String   @db.Text
  limitations  String   @db.Text
  whyMoved     String?  @db.Text

  relatedDashboards String[]
  relatedKpiSlugs   String[]

  history       KpiHistoryPoint[]
  conversations AiConversation[]
  lineageFlow   LineageFlow?
  /// optional link to the live data source backing this KPI (Phase B)
  connectionId  String?
  connection    SourceConnection? @relation(fields: [connectionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, domain])
  @@index([workspaceId, status])
}

model KpiHistoryPoint {
  id     String   @id @default(cuid())
  kpiId  String
  period String
  value  Float
  at     DateTime?

  kpi Kpi @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
}

// ─── Lineage ────────────────────────────────────────────────────────────────
enum LineageKind {
  SOURCE
  STAGING
  TRANSFORM
  SEMANTIC
  DASHBOARD
  KPI
}

model LineageFlow {
  id          String @id @default(cuid())
  workspaceId String
  kpiId       String @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kpi   Kpi          @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  steps LineageStep[]
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model LineageStep {
  id      String      @id @default(cuid())
  flowId  String
  ordinal Int
  label   String
  detail  String      @db.Text
  kind    LineageKind
  owner   String?
  refresh String?
  status  String?    // "Active" | "Stale" | "Failed"

  flow LineageFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
}

// ─── AI ──────────────────────────────────────────────────────────────────────
enum MessageRole {
  USER
  AGENT
}

model AiConversation {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  kpiId       String?
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  kpi       Kpi?       @relation(fields: [kpiId], references: [id], onDelete: SetNull)
  messages  AiMessage[]

  @@index([workspaceId, userId])
  @@index([kpiId])
}

model AiMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  sources        String[]
  assumptions    String[]
  followUps      String[]
  confidence     Int?
  /// model and provider used for the response (audit)
  model          String?
  provider       String?
  inputTokens    Int?
  outputTokens   Int?
  costUsdCents   Int?
  createdAt      DateTime    @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────
model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  action      String   // "kpi.create", "kpi.update", "kpi.certify", "ai.ask", "source.connect", ...
  targetType  String?  // "kpi", "conversation", "source", "workspace"
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([action])
}

// ─── Sources / connectors (Phase B) ──────────────────────────────────────────
enum SourceKind {
  POSTGRES
  MSSQL
  SNOWFLAKE
  BIGQUERY
  SALESFORCE
  COUPA
  WORKDAY
  POWERBI
  SAP
  CSV
  EXCEL
}

enum SourceStatus {
  PENDING
  CONNECTED
  ERROR
  DISABLED
}

model SourceConnection {
  id          String       @id @default(cuid())
  workspaceId String
  kind        SourceKind
  name        String       // human-friendly: "Snowflake — Finance prod"
  status      SourceStatus @default(PENDING)
  /// AES-256-GCM encrypted credentials blob. Key is server-side env.
  /// Schema differs per `kind` — parsed on use.
  credentialsCipher String?  @db.Text
  /// Non-secret connection config — host, port, db name, scope, etc.
  config Json?
  lastSyncAt   DateTime?
  lastError    String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  kpis      Kpi[]

  @@index([workspaceId, kind])
}
