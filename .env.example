# =============================================================================
# OpenKPI Studio - Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in your keys.
# `.env.local` is git-ignored and will NEVER be committed.
#
# The MVP runs fully on deterministic mock AI responses, so none of these are
# required to launch the UI. They unlock real LLM-powered explanations once
# you flip OPENKPI_AI_PROVIDER away from "mock".
# =============================================================================

# ---- AI provider selection -------------------------------------------------
# Options: mock | openai | anthropic | azure-openai
OPENKPI_AI_PROVIDER=mock

# ---- OpenAI ----------------------------------------------------------------
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-goes-here
OPENAI_MODEL=gpt-4o-mini

# ---- Anthropic (Claude) ----------------------------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-goes-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Azure OpenAI (enterprise) ---------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ---- Database --------------------------------------------------------------
DATABASE_URL=postgresql://openkpi:your-strong-password@your-db-host:5432/openkpi?schema=public

# ---- Connector credential encryption ---------------------------------------
# Generate with: openssl rand -base64 32
# Used to encrypt SourceConnection credentialsCipher columns at rest.
# Rotating this key invalidates all stored credentials (you'll need to re-add).
ENCRYPTION_KEY=replace-with-openssl-rand-base64-32-output

# ---- Cron shared secret (Bearer token for /api/cron/* endpoints) ----------
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-openssl-rand-hex-32-output

# ---- NextAuth --------------------------------------------------------------
NEXTAUTH_URL=https://your-domain.example.com
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email magic link (any SMTP relay)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="OpenKPI Studio <noreply@example.com>"
